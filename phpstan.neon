includes:
  - phpstan-baseline.neon

parameters:
  level: 1

  bootstrapFiles:
    - phpstan.bootstrap

  stubFiles:
    - stubs/Module.stub
    - stubs/Tab.stub

  dynamicConstantNames:
    - _PS_VERSION_
    - _PS_MODE_DEV_
    - _PS_MODE_DEMO_

  paths:
    - mondialrelay.php
    - src
    - classes
    - controllers

  reportUnmatchedIgnoredErrors: true

