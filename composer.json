{
  "name": "nikrou/simplecarrier",
    "description": "SimpleCarrier is a module for PrestaShop",
  "license": "OSL-3.0",
  "authors": [
    {
      "name": "Nicolas Roudaire",
      "email": "nikrou77@gmail.com"
    }
  ],
  "require": {
    "php": ">=8.4",
    "prestashop/module-lib-service-container": "^2.0",
    "symfony/http-client": "^8.0"
  },
  "config": {
    "vendor-dir": "vendor",
    "preferred-install": "dist",
    "optimize-autoloader": true,
    "prepend-autoloader": false,
    "platform": {
        "php": "8.4"
    },
    "sort-packages": true,
    "bin-dir": "bin"
  },
  "autoload": {
    "classmap": [
      "mondialrelay.php",
      "classes/"
    ],
    "psr-4": {
      "MondialrelayClasslib\\": "totpsclasslib/src/",
      "MondialRelay\\MondialRelay\\": "src/"
    }
  },
  "scripts": {
    "pre-autoload-dump": "if [ ${TOTPSCLASSLIB_DEV_PATH} ]; then php ${TOTPSCLASSLIB_DEV_PATH}/classlib/refresh.php .; fi",
    "phpstan": "phpstan analyse",
    "rector": "rector process",
    "php-cs-fixer": "php-cs-fixer fix --allow-unsupported-php-version=yes"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.86",
    "phpstan/phpstan": "^2.1",
    "rector/rector": "^2.3"
  }
}
